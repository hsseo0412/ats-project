APP_NAME="Laravel Boilerplate"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ----------------------------------------
# Logging
# ----------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DAILY_DAYS=90
LOG_ERROR_DAYS=180
LOG_INFO_DAYS=30
LOG_API_DAYS=30

# ----------------------------------------
# Database
# ----------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# ----------------------------------------
# Cache / Session / Queue → Redis
# ----------------------------------------
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ----------------------------------------
# Sanctum
# ----------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:8000

# ----------------------------------------
# Mail (개발용)
# ----------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------
# 파일 스토리지
# ----------------------------------------
FILESYSTEM_DISK=local

# ----------------------------------------
# Telescope (로컬에서만 활성화)
# ----------------------------------------
TELESCOPE_ENABLED=true
